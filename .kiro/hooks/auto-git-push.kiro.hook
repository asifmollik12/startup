{
  "enabled": true,
  "name": "Auto Git Push",
  "description": "Automatically commits and pushes changes to GitHub after every file save, triggering a Vercel deployment",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git diff --cached --quiet || git commit -m \"Auto-save: update project files\" && git push origin main",
    "timeout": 60
  }
}