{
  "enabled": true,
  "name": "Auto Git Push",
  "description": "Automatically stages, commits, and pushes all changes to git after any file is edited",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"Auto-save: update project files\" && git push"
  }
}